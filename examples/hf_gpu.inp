# Calculation inputs
verbose = 5
max_memory = 8000 # MB
method = hf 
cal_mode = energy
int_storage = 2 # 0: incore, 1: outcore, 2:direct 3: GPU-incore

# GPU inputs
ngpu = 1
gpu_memory = 3000
use_df_hf = False # where DF is used for HF. If False, int_storage must be 2

# Molecule inputs
basis = ccpvtz
charge = 0
spin = 0
xyz_file = ./water8.xyz # Path to the xyz file
